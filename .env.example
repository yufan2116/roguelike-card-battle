# Server
PORT=3001
NODE_ENV=development

# Image generation (Phase 5) — 图片 API，与 LLM 分开配置
IMAGE_API_KEY=
IMAGE_API_BASE_URL=https://api.openai.com/v1/images/generations
IMAGE_MODEL=dall-e-3

# LLM generation (Phase 6) — 文本/JSON 生成 API，与图片分开配置
LLM_API_KEY=
LLM_API_BASE_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini

# Storage paths (relative to project root)
DATA_DIR=./data
ASSETS_DIR=./assets
DB_PATH=./data/game.db
